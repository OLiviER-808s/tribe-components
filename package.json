{
    "name": "@olivier808s/tribe-components",
    "version": "4.1.3",
    "description": "A Vue 3 component library with 30+ reusable, themeable UI components",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/OLiviER-808s/tribe-components.git"
    },
    "homepage": "https://github.com/OLiviER-808s/tribe-components#readme",
    "bugs": {
        "url": "https://github.com/OLiviER-808s/tribe-components/issues"
    },
    "keywords": ["vue", "vue3", "components", "ui", "component-library", "tailwind"],
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        },
        "./style.css": "./dist/style.css",
        "./theme.css": "./dist/theme.css"
    },
    "files": [
        "dist"
    ],
    "publishConfig": {
        "registry": "https://registry.npmjs.org/",
        "access": "public"
    },
    "scripts": {
        "build:css": "npx @tailwindcss/cli -i ./src/styles/style.css -o ./dist/style.css --minify",
        "build": "vite build",
        "type-check": "vue-tsc --noEmit",
        "build:watch": "vite build --watch"
    },
    "peerDependencies": {
        "@fortawesome/fontawesome-svg-core": "^6.5.1",
        "@fortawesome/free-brands-svg-icons": "^6.5.1",
        "@fortawesome/free-regular-svg-icons": "^6.5.1",
        "@fortawesome/vue-fontawesome": "^3.0.6",
        "vue": "^3.2.0"
    },
    "peerDependenciesMeta": {
        "@fortawesome/fontawesome-svg-core": { "optional": true },
        "@fortawesome/free-brands-svg-icons": { "optional": true },
        "@fortawesome/free-regular-svg-icons": { "optional": true },
        "@fortawesome/vue-fontawesome": { "optional": true }
    },
    "dependencies": {
        "@vuepic/vue-datepicker": "^8.6.0",
        "@vueuse/core": "^10.9.0",
        "@vueuse/gesture": "^2.0.0",
        "@vueuse/motion": "^2.2.6",
        "cropperjs": "^1.6.1",
        "dompurify": "^3.1.6",
        "swiper": "^12.1.2",
        "uuid": "^9.0.1",
        "vue-final-modal": "^4.5.4",
        "vuedraggable": "^4.1.0"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "^4.2.1",
        "@types/node": "^25.1.0",
        "@types/uuid": "^10.0.0",
        "@vitejs/plugin-vue": "^6.0.0",
        "postcss": "^8.5.6",
        "tailwindcss": "^4.2.1",
        "typescript": "^5.9.3",
        "vite": "^7.0.4",
        "vite-plugin-dts": "^4.5.4",
        "vue": "^3.5.17",
        "vue-tsc": "^3.2.4"
    }
}
