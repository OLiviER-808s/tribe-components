{
    "name": "@OLiviER-808s/tribe-components",
    "version": "2.0.0",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        },
        "./style.css": "./dist/style.css",
        "./theme.css": "./dist/theme.css"
    },
    "files": [
        "dist"
    ],
    "publishConfig": {
        "registry": "https://npm.pkg.github.com/"
    },
    "scripts": {
        "build:theme": "tailwindcss -i ./src/styles/theme.css -o ./dist/theme.css --minify",
        "build:style": "tailwindcss -i ./src/styles/style.css -o ./dist/style.css --minify",
        "build:css": "npm run build:theme && npm run build:style",
        "build": "vite build",
        "type-check": "vue-tsc --noEmit"
    },
    "peerDependencies": {
        "@fortawesome/fontawesome-svg-core": "^6.5.1",
        "@fortawesome/free-brands-svg-icons": "^6.5.1",
        "@fortawesome/free-regular-svg-icons": "^6.5.1",
        "@fortawesome/free-solid-svg-icons": "^6.5.1",
        "@fortawesome/vue-fontawesome": "^3.0.6",
        "vue": "^3.2.0"
    },
    "dependencies": {
        "@vuepic/vue-datepicker": "^8.6.0",
        "@vueuse/core": "^10.9.0",
        "@vueuse/gesture": "^2.0.0",
        "@vueuse/motion": "^2.2.6",
        "cropperjs": "^1.6.1",
        "dompurify": "^3.1.6",
        "swiper": "^11.1.14",
        "uuid": "^9.0.1",
        "v-dropdown-menu": "^2.0.4",
        "vue-final-modal": "^4.5.4",
        "vuedraggable": "^4.1.0"
    },
    "devDependencies": {
        "@types/node": "^25.1.0",
        "@types/uuid": "^10.0.0",
        "@vitejs/plugin-vue": "^6.0.0",
        "autoprefixer": "^10.4.21",
        "postcss": "^8.5.6",
        "tailwindcss": "^3.2.1",
        "typescript": "^5.9.3",
        "vite": "^7.0.4",
        "vue": "^3.5.17",
        "vue-tsc": "^3.2.4"
    }
}
